  originalText: "\u0646\u0648\u0648\u0633\u06CC\u0646\u06CC \u0633\u0627\u062F\u06D5\u060C
    \u06A9\u06C6\u0645\u0627\u060C \u062F\u0648\u0648 \u062E\u0627\u06B5: \u0695\u0627\u06AF\u06D5\u06CC\u0627\u0646\u062F\u0646\u06CC
    \xAB\u0626\u0627\u0632\u0627\u062F\u06CC\xBB\u06CC \u062E\u06D5\u06B5\u06A9\u060C
    \u0695\u0627\u0633\u062A\u06D5\u0648\u062E\u06C6\u060C \u0628\u06D5 \u0628\u06CE
    \u067E\u06CE\u0686 \u0648 \u067E\u0627\u06B5.\r\n\r\n"
