  originalText: "\u06A9\u0627\u062A\u06CE\u06A9 \u06AF\u0648\u06CE\u0628\u06CC\u0633\u062A\u06CC
    \u0647\u06D5\u0648\u0627\u06B5\u06CC \u0645\u06D5\u0631\u06AF\u06CC \u0626\u0627\u0632\u06CC\u0632\u06CE\u06A9\u0645\u0627\u0646
    \u062F\u06D5\u0628\u06CC\u0646 \u0695\u0627\u0633\u062A\u06D5\u0648\u062E\u06C6
    \u062F\u06D5\u06A9\u06D5\u0648\u06CC\u0646\u06D5 \u062F\u06C6\u062E\u06CE\u06A9\u06CC
    \u0646\u0627\u0647\u06D5\u0645\u0648\u0627\u0631\u06D5\u0648\u06D5\u060C \u0648
    \u0628\u0695\u0648\u0627\u0645\u0627\u0646 \u0646\u06D5\u06A9\u0631\u062F\u0648\u0648\u06D5
    \u0695\u06C6\u0698\u06CE\u06A9 \u062F\u06CE\u062A \u0648 \u0628\u06D5\u062C\u06CE\u0645\u0627\u0646
    \u062F\u06CE\u06B5\u06CE \u0648 \u0626\u06CE\u0645\u06D5 \u0644\u06D5\u0698\u06CC\u0627\u0646
    \u06A9\u0631\u062F\u0646 \u0628\u06D5\u0631\u062F\u06D5\u0648\u0627\u0645 \u062F\u06D5\u0628\u06CC\u0646.
    \u0632\u06C6\u0631\u062C\u0627\u0631 \u06AF\u0648\u06CE\u0628\u06CC\u0633\u062A\u06CC
    \u0626\u06D5\u0648\u06D5 \u062F\u06D5\u0628\u06CC\u0646 \u06A9\u06D5 \u062F\u06D5\u06B5\u06CE\u0646
    \u0644\u06D5\u062F\u0648\u0627\u06CC \u0645\u06D5\u0631\u06AF\u06CC \u062A\u06C6
    \u0645\u0646\u06CC\u0634 \u0695\u0627\u0633\u062A\u06D5\u0648\u062E\u06C6 \u062F\u06D5\u0645\u0631\u0645
    \u0648 \u0628\u06D5\u0631\u06AF\u06D5 \u0646\u0627\u06AF\u0631\u0645\u060C \u0628\u06D5\u06B5\u0627\u0645
    \u0686\u06CC \u0695\u0648\u0648\u062F\u06D5\u062F\u0627\u062A \u0626\u06D5\u06AF\u06D5\u0631
    \u0626\u06D5\u0648 \u06A9\u06D5\u0633\u06D5\u06CC \u06A9\u06D5 \u0628\u06D5\u0631\u06AF\u06D5\u06CC
    \u0645\u06D5\u0631\u06AF\u06CC \u0626\u0627\u0632\u06CC\u0632\u06CE\u06A9\u06CC
    \u0646\u06D5\u062F\u06D5\u06AF\u0631\u062A \u062E\u06C6\u06CC \u0646\u06D5\u062E\u0634\u06D5\u06CC
    \u06A9\u0648\u0634\u062A\u0646\u06CC \u062F\u0627\u0695\u0634\u062A\u0628\u06CE\u062A\u061F
    \u0647\u06CE\u0646\u062F\u06D5 \u062E\u06C6\u0634\u06CC\u062F\u06D5\u0648\u06CC\u0633\u062A
    \u0644\u06D5\u06A9\u06C6\u062A\u0627 \u0645\u0627\u0686\u06CC \u062E\u06C6\u0634\u06D5\u0648\u06CC\u0633\u062A\u06CC\u062F\u0627
    \u0645\u06D5\u0631\u06AF \u062F\u06D5\u06A9\u0627\u062A \u0628\u06D5\u062F\u06CC\u0627\u0631\u06CC
    \u0628\u06C6\u06CC.\r\n\u0648\u06D5\u06B5\u0627\u0645\u06CC \u0626\u06D5\u0645
    \u067E\u0631\u0633\u06CC\u0627\u0631\u06D5 \u062F\u06D5\u06A9\u06D5\u06CC\u0646\u06D5
    \u062F\u06D5\u0631\u0648\u0627\u0632\u06D5\u06CC\u06D5\u06A9 \u0628\u06C6 \u0686\u0648\u0648\u0646\u06D5
    \u0646\u0627\u0648 \u0695\u06C6\u0645\u0627\u0646\u06CC (\u0645\u0627\u0686\u06CC
    \u067E\u06CE\u0634 \u0645\u06D5\u0631\u06AF)\u06D5\u0648\u06D5\u060C \u0644\u06CE\u0631\u06D5\u0648\u06D5
    \u0626\u0627\u0634\u0646\u0627\u06CC \u06A9\u06D5\u0633\u0627\u06CC\u06D5\u062A\u06CC\u06D5\u06A9\u0627\u0646\u06CC
    \u0646\u0627\u0648 \u0695\u06C6\u0645\u0627\u0646\u06D5\u06A9\u06D5 \u062F\u06D5\u0628\u06CC\u0646."
